                    "pluginVersion": "4.14.0",
                    "queryType": "table",
                    "rawSql": "SELECT \r\n    window_start AS time,\r\n    store, \r\n    checkout,\r\n    countIf(payment = 'cash') AS cash_payments,\r\n    countIf(payment = 'card') AS card_payments,\r\n    countIf(payment = 'gift card') AS gift_payments\r\nFROM retail_stats.payment_analytics\r\nWHERE $__timeFilter(window_start)\r\n  AND store = '$unique_store' \r\n  AND checkout IN ($checkout)\r\nGROUP BY store, checkout, window_start\r\nORDER BY time",
                    "refId": "A"
                }
            ],
            "title": "Payment methods in Store $unique_store",
            "type": "timeseries"
        },
